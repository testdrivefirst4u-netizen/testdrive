generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  USER
  DEALER_ADMIN
  SALES_EXECUTIVE
}

enum DealerStatus {
  ACTIVE
  INACTIVE
  VACATION
  MAINTENANCE
  CLOSED
}

enum VehicleType {
  CAR
  BIKE
  SCOOTER
  EV
  COMMERCIAL
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  email       String   @unique
  password    String?
  role        Role     @default(USER)
  image       String?
  permissions String[] @default([])
  phone       String?
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  // CRM: which dealer this user belongs to (DEALER_ADMIN or SALES_EXECUTIVE)
  dealerId    String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  dealer      Dealer?  @relation("DealerStaff", fields: [dealerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminDealer Dealer?  @relation("DealerAdmin")
  assignedLeads CrmLead[] @relation("LeadExecutive")

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Brand {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String        @unique
  slug        String        @unique
  logo        String?
  logoFileId  String?
  description String?
  country     String?
  founded     Int?
  isPopular   Boolean       @default(false)
  status      PublishStatus @default(PUBLISHED)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vehicles        Vehicle[]
  seo             Seo?
  leads           Lead[]              @relation("LeadBrand")
  dealers         Dealer[]            @relation("DealerBrand")
  crmLeads        CrmLead[]           @relation("CrmLeadBrand")
  assignmentRule  CrmAssignmentRule?  @relation("BrandAssignmentRule")

  @@map("brands")
}

model Category {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String      @unique
  slug        String      @unique
  type        VehicleType
  description String?
  icon        String?
  image       String?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  vehicles Vehicle[]

  @@map("categories")
}

model Vehicle {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String        @unique
  brandId          String        @db.ObjectId
  categoryId       String        @db.ObjectId
  type             VehicleType
  description      String?
  shortDescription String?

  priceMin        Float?
  priceMax        Float?
  priceDisplay    String?
  exShowroomPrice Float?
  onRoadPrice     Float?

  launchDate       DateTime?
  discontinuedDate DateTime?
  isUpcoming       Boolean   @default(false)
  isPopular        Boolean   @default(false)
  isElectric       Boolean   @default(false)
  isNew            Boolean   @default(false)

  batteryCapacity String?
  chargingTime    String?
  fastCharging    Boolean @default(false)
  range           String?
  motorPower      String?
  motorTorque     String?

  bodyType  String?
  segment   String?
  mileage   String?
  topSpeed  String?
  engine    String?
  power     String?
  torque    String?

  overview      String?
  keyHighlights Json?
  pros          Json?
  cons          Json?

  brochureUrl    String?
  brochureFileId String?
  videoUrl       String?

  featured           Boolean @default(false)
  availabilityStatus String  @default("available")
  featuredImage      String?
  featuredFileId     String?

  acceleration     String?
  acChargingTime   String?
  dcChargingTime   String?
  chargingPortType String?
  drivetrainType   String?
  seatingCapacity  Int?

  vehicleWarranty String?
  batteryWarranty String?

  status    PublishStatus @default(DRAFT)
  sortOrder Int           @default(0)
  viewCount Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  variants     Variant[]
  images       VehicleImage[]
  colours      VehicleColour[]
  specGroups   VehicleSpecGroup[]
  features     VehicleFeature[]
  faqs         Faq[]
  seo          Seo?
  media        Media[]
  dealerOffers DealerVehicleOffer[]

  @@map("vehicles")
}

model Variant {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId    String        @db.ObjectId
  name         String
  slug         String
  priceMin     Float?
  priceMax     Float?
  priceDisplay String?
  fuelType     String?
  transmission String?
  engine       String?
  power        String?
  torque       String?
  mileage      String?
  range        String?
  isDefault    Boolean       @default(false)
  status       PublishStatus @default(PUBLISHED)
  sortOrder    Int           @default(0)
  specs        Json?
  features     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("variants")
}

model VehicleImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  url       String
  fileId    String?
  alt       String?
  caption   String?
  type      String   @default("gallery")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_images")
}

model VehicleColour {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  name      String
  hexCode   String?
  imageUrl  String?
  fileId    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_colours")
}

model SpecGroup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specItems    SpecItem[]
  vehicleSpecs VehicleSpecGroup[]

  @@map("spec_groups")
}

model SpecItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String   @db.ObjectId
  name        String
  slug        String
  unit        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  group      SpecGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  specValues VehicleSpecValue[]

  @@map("spec_items")
}

model VehicleSpecGroup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  groupId   String   @db.ObjectId
  createdAt DateTime @default(now())

  vehicle    Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  group      SpecGroup        @relation(fields: [groupId], references: [id])
  specValues VehicleSpecValue[]

  @@map("vehicle_spec_groups")
}

model VehicleSpecValue {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleSpecGroupId String   @db.ObjectId
  specItemId         String   @db.ObjectId
  value              String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicleSpecGroup VehicleSpecGroup @relation(fields: [vehicleSpecGroupId], references: [id], onDelete: Cascade)
  specItem         SpecItem         @relation(fields: [specItemId], references: [id])

  @@map("vehicle_spec_values")
}

model VehicleFeature {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String  @db.ObjectId
  category  String
  name      String
  available Boolean @default(true)
  note      String?
  sortOrder Int     @default(0)

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_features")
}

model News {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  coverImage  String?
  coverFileId String?
  author      String?
  tags        Json?
  vehicleId   String?
  brandId     String?
  type        String        @default("news")
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seo Seo?

  @@map("news")
}

model Blog {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  coverImage  String?
  coverFileId String?
  author      String?
  tags        Json?
  type        String        @default("article")
  vehicleId   String?
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seo Seo?

  @@map("blogs")
}

model Faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String?  @db.ObjectId
  question  String
  answer    String
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("faqs")
}

model Seo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId       String?  @unique @db.ObjectId
  brandId         String?  @unique @db.ObjectId
  newsId          String?  @unique @db.ObjectId
  blogId          String?  @unique @db.ObjectId
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schema          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brand   Brand?   @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  news    News?    @relation(fields: [newsId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blog    Blog?    @relation(fields: [blogId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("seo")
}

model Media {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId  String?  @db.ObjectId
  name       String
  fileName   String
  fileId     String
  url        String
  type       String
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  alt        String?
  tags       Json?
  uploadedBy String?
  createdAt  DateTime @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("media")
}

model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String?
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Banner {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  subtitle  String?
  imageUrl  String
  fileId    String?
  linkUrl   String?
  linkLabel String?
  position  String    @default("hero")
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("banners")
}

model Lead {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  mobile      String
  email       String?
  city        String?
  vehicleName String?
  vehicleType String?
  buyTime     String?
  sellCar     String?
  source      String   @default("offer_popup")
  status      String   @default("new")
  notes       String?
  brandId     String?  @db.ObjectId
  dealerId    String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand      Brand?         @relation("LeadBrand",  fields: [brandId],  references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealer     Dealer?        @relation("LeadDealer", fields: [dealerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  activities LeadActivity[]

  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId    String   @db.ObjectId
  userId    String?
  userName  String?
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?
  userName  String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─── CRM: Dealer Management ─────────────────────────────────────────────────

model Dealer {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  code            String       @unique
  brandId         String       @db.ObjectId
  email           String
  phone           String
  managerName     String?
  managerPhone    String?
  address         String?
  city            String
  state           String
  pincodes        String[]
  status          DealerStatus @default(ACTIVE)
  priority        Int          @default(1)
  weight          Int          @default(1)
  maxLeadsPerDay  Int          @default(50)
  autoAssign      Boolean      @default(true)
  isAvailable     Boolean      @default(true)
  todayLeadCount  Int          @default(0)
  lastCountReset  DateTime     @default(now())
  lastAssignedAt  DateTime?
  adminUserId     String?      @unique @db.ObjectId
  businessHours   Json?
  logo            String?
  assignedVehicles String[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  brand        Brand               @relation("DealerBrand", fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminUser    User?               @relation("DealerAdmin", fields: [adminUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff        User[]              @relation("DealerStaff")
  leads        Lead[]              @relation("LeadDealer")
  crmLeads     CrmLead[]
  followUps    CrmFollowUp[]
  testDrives   CrmTestDrive[]
  vehicleOffers DealerVehicleOffer[]

  @@map("dealers")
}

// ─── CRM: Leads (separate from basic website Lead) ──────────────────────────

model CrmLead {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  customerName     String
  mobile           String
  email            String?
  city             String?
  state            String?
  pincode          String?
  budget           Float?
  remarks          String?
  consent          Boolean  @default(false)

  // Vehicle interest
  brandId          String?  @db.ObjectId
  vehicle          String?
  variant          String?
  fuelType         String?
  transmission     String?

  // Assignment
  dealerId         String?  @db.ObjectId
  executiveId      String?  @db.ObjectId
  assignedAt       DateTime?
  openedAt         DateTime?
  reassignTimer    DateTime?
  assignmentAttempts Int    @default(0)

  // Source & tracking
  source           String   @default("website")
  status           String   @default("new")
  priority         String   @default("medium")

  // Duplicate detection
  isDuplicate      Boolean  @default(false)
  duplicateOfId    String?  @db.ObjectId

  // Activity (stored as JSON arrays)
  history          Json?
  leadNotes        Json?
  tags             String[]

  // UTM
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brand     Brand?   @relation("CrmLeadBrand", fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealer    Dealer?  @relation(fields: [dealerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executive User?    @relation("LeadExecutive", fields: [executiveId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  followUps  CrmFollowUp[]
  testDrives CrmTestDrive[]
  bookings   CrmBooking[]

  @@map("crm_leads")
}

// ─── CRM: Assignment Rules ───────────────────────────────────────────────────

model CrmAssignmentRule {
  id                   String  @id @default(auto()) @map("_id") @db.ObjectId
  brandId              String  @unique @db.ObjectId
  strategy             String  @default("round_robin")
  lastAssignedIndex    Int     @default(-1)
  lastAssignedDealerId String? @db.ObjectId
  autoReassignEnabled  Boolean @default(true)
  reassignAfterMinutes Int     @default(30)
  afterHoursAction     String  @default("queue")
  dealer24x7Id         String? @db.ObjectId
  pincodeMap           Json?
  cityMap              Json?
  vehicleMap           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  brand Brand @relation("BrandAssignmentRule", fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("crm_assignment_rules")
}

// ─── CRM: Follow-ups ────────────────────────────────────────────────────────

model CrmFollowUp {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId      String   @db.ObjectId
  dealerId    String   @db.ObjectId
  executiveId String?  @db.ObjectId
  scheduledAt DateTime
  type        String   @default("call")
  note        String?
  status      String   @default("pending")
  outcome     String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead   CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealer Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@map("crm_follow_ups")
}

// ─── CRM: Test Drives ───────────────────────────────────────────────────────

model CrmTestDrive {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId      String   @db.ObjectId
  dealerId    String   @db.ObjectId
  vehicle     String
  variant     String?
  scheduledAt DateTime
  status      String   @default("scheduled")
  feedback    String?
  rating      Int?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead   CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealer Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@map("crm_test_drives")
}

// ─── CRM: Bookings ──────────────────────────────────────────────────────────

model CrmBooking {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId           String   @db.ObjectId
  bookingNumber    String   @unique
  vehicle          String
  variant          String?
  color            String?
  bookingAmount    Float?
  vehiclePrice     Float?
  financeRequired  Boolean  @default(false)
  financeAmount    Float?
  insuranceAmount  Float?
  accessoriesAmount Float?
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  status           String   @default("pending")
  invoiceNumber    String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lead CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("crm_bookings")
}

// ─── CRM: Audit Log ─────────────────────────────────────────────────────────

model CrmAuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  action     String
  entity     String?
  entityId   String?  @db.ObjectId
  doneById   String?  @db.ObjectId
  doneByRole String?
  ip         String?
  userAgent  String?
  changes    Json?
  dealerId   String?  @db.ObjectId
  brandId    String?  @db.ObjectId
  createdAt  DateTime @default(now())

  @@map("crm_audit_logs")
}

model NewsletterSubscriber {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  name           String?
  source         String?   @default("website")
  status         String    @default("active")
  tags           String[]  @default([])
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

// ─── Dealer Vehicle Offers ───────────────────────────────────────────────────

model DealerVehicleOffer {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  dealerId     String    @db.ObjectId
  vehicleId    String    @db.ObjectId
  variantName  String?
  offerPrice   Float?
  discount     Float?
  discountType String?   // "percentage" | "fixed"
  priceDisplay String?
  validFrom    DateTime?
  validUntil   DateTime?
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dealer  Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("dealer_vehicle_offers")
}

// ─── User Saved Vehicles ─────────────────────────────────────────────────────

model SavedVehicle {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  vehicleId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, vehicleId])
  @@map("saved_vehicles")
}

// ─── Price Drop Alerts ───────────────────────────────────────────────────────

model PriceAlert {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?   @db.ObjectId
  email       String
  vehicleId   String    @db.ObjectId
  targetPrice Float?
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("price_alerts")
}
